{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Windrose": {
    "ServerRoot": "/opt/windrose/server-files",
    "ComposeDirectory": "/opt/windrose",
