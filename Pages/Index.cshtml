@page
@model IndexModel
@{
    ViewData["Title"] = "Windrose Save Manager";
}

<div class="loading-overlay" data-loading-overlay hidden>
    <div class="loading-panel" role="status" aria-live="polite">
        <div class="spinner" aria-hidden="true"></div>
        <h2 data-loading-title>Working...</h2>
        <p data-loading-message>Please keep this page open.</p>
    </div>
</div>

<section class="hero">
    <div>
        <p class="eyebrow">Windrose</p>
        <h1>Save Manager</h1>
    </div>
    <form method="post" asp-page-handler="Backup" data-loading-message="Backing up the active Windrose world...">
        <button class="button secondary" type="submit">Backup Active World</button>
    </form>
</section>

@if (Model.LastOperation is not null)
{
    <div class="notice @(Model.LastOperation.Succeeded ? "success" : "danger")">
        @Model.LastOperation.Message
    </div>
}

@if (Model.State?.Warnings.Count > 0)
{
    foreach (var warning in Model.State.Warnings)
    {
        <div class="notice warning">@warning</div>
    }
}

<section class="import-panel">
    <div>
        <h2>Import World Zip</h2>
        <p>Upload a zip containing one Windrose world folder. The friendly name is read from WorldDescription.json.</p>
    </div>
    <form method="post" asp-page-handler="Import" enctype="multipart/form-data" data-loading-message="Importing the Windrose world zip...">
        <input type="file" name="WorldZip" accept=".zip" required />
        <button class="button" type="submit">Import Zip</button>
    </form>
</section>

<section class="summary">
    <div>
        <span>Active World</span>
        <strong>@(Model.State?.ActiveWorldName ?? "Unknown")</strong>
    </div>
    <div>
        <span>World ID</span>
        <code>@(Model.State?.ActiveWorldId ?? "Not set")</code>
    </div>
    <div>
        <span>Worlds Folder</span>
        <code>@(Model.State?.WorldsRoot ?? "Not found")</code>
    </div>
    <div>
        <span>Session Name</span>
        <strong>@(Model.State?.Settings.ServerName ?? "Not set")</strong>
    </div>
    <div>
        <span>Password</span>
        <strong>@(Model.State?.Settings.IsPasswordProtected == true || Model.State?.Settings.HasPassword == true ? "Protected" : "Open")</strong>
    </div>
</section>

<section class="settings-panel">
    <div class="section-heading">
        <div>
            <h2>Server Settings</h2>
            <p>Only checked fields are saved. Unchecked values are left unchanged.</p>
        </div>
    </div>

    <form method="post" asp-page-handler="SaveServerSettings" data-loading-message="Stopping Windrose, saving server settings, and starting the server again...">
        <label class="check-row">
            <input type="checkbox" name="UpdateServerName" value="true" />
            <span>Update session name</span>
        </label>
        <input type="text" name="ServerName" value="@Model.State?.Settings.ServerName" placeholder="Windrose session name" />

        <label class="check-row">
            <input type="checkbox" name="UpdatePassword" value="true" />
            <span>Set or replace password</span>
        </label>
        <input type="password" name="ServerPassword" placeholder="New server password" autocomplete="new-password" />

        <label class="check-row">
            <input type="checkbox" name="ClearPassword" value="true" />
            <span>Remove password protection</span>
        </label>

        <button class="button" type="submit">Save Server Settings</button>
    </form>
</section>

<section class="worlds">
    <div class="section-heading">
        <h2>Available Worlds</h2>
        <span>@(Model.State?.Worlds.Count ?? 0) found</span>
    </div>

    @if (Model.State?.Worlds.Count > 0)
    {
        <div class="world-grid">
            @foreach (var world in Model.State.Worlds)
            {
                <article class="world-card @(world.IsActive ? "active" : "")">
                    <div>
                        <h3>@world.Name</h3>
                        <code>@world.Id</code>
                    </div>
                    <dl>
                        <div>
                            <dt>Version</dt>
                            <dd>@world.Version</dd>
                        </div>
                        <div>
                            <dt>Modified</dt>
                            <dd>@world.LastModified.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</dd>
                        </div>
                    </dl>
                    @if (!string.IsNullOrWhiteSpace(world.GameName) || !string.IsNullOrWhiteSpace(world.Alias))
                    {
                        <p class="world-meta">
                            Game name: @(world.GameName ?? "Unknown")
                            @if (!string.IsNullOrWhiteSpace(world.Alias))
                            {
                                <span>Label: @world.Alias</span>
                            }
                        </p>
                    }

                    <form class="alias-form" method="post" asp-page-handler="SaveAlias" data-loading-message="Saving the display label...">
                        <input type="hidden" name="WorldId" value="@world.Id" />
                        <input type="text" name="Alias" value="@world.Alias" placeholder="Optional display label" />
                        <button class="button secondary" type="submit">Save Label</button>
                    </form>

                    @if (world.IsActive)
                    {
                        <span class="active-pill">Active</span>
                    }
                    else
                    {
                        <form method="post" asp-page-handler="Activate" data-loading-message="Switching to @world.Name. Backing up, stopping Windrose, activating the world, and starting the server again...">
                            <input type="hidden" name="WorldId" value="@world.Id" />
                            <button class="button" type="submit">Activate</button>
                        </form>
                    }

                    <details class="advanced-settings">
                        <summary>Advanced World Settings</summary>
                        <form method="post" asp-page-handler="SaveWorldSettings" data-loading-message="@(world.IsActive ? $"Stopping Windrose, backing up {world.Name}, saving world settings, and starting the server again..." : $"Backing up and saving settings for inactive world {world.Name}. The running server will not be restarted.")">
                            <input type="hidden" name="WorldId" value="@world.Id" />

                            <label>
                                <span>Preset</span>
                                <select name="PresetType" data-preset-select>
                                    <option value="Easy" selected="@(world.Settings.PresetType.Equals("Easy", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Easy</option>
                                    <option value="Medium" selected="@(world.Settings.PresetType.Equals("Medium", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Medium</option>
                                    <option value="Hard" selected="@(world.Settings.PresetType.Equals("Hard", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Hard</option>
                                    <option value="Custom" selected="@(world.Settings.PresetType.Equals("Custom", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Custom</option>
                                </select>
                            </label>

                            <p class="world-meta">Custom parameters only apply when preset is Custom. Non-custom presets save empty WorldSettings.</p>

                            <label>
                                <span class="field-label">
                                    Shared co-op quests
                                    <button class="help-button" type="button" aria-label="Shared co-op quests help" data-tooltip="When a player completes a co-op quest, it auto-completes for all players who have it active.">?</button>
                                </span>
                                <select name="SharedQuests" data-custom-setting>
                                    <option value="true" selected="@(world.Settings.SharedQuests ? "selected" : null)">True</option>
                                    <option value="false" selected="@(!world.Settings.SharedQuests ? "selected" : null)">False</option>
                                </select>
                            </label>

                            <label>
                                <span class="field-label">
                                    Immersive exploration
                                    <button class="help-button" type="button" aria-label="Immersive exploration help" data-tooltip="Hides map markers for points of interest, making exploration harder. Called Immersive Exploration in-game.">?</button>
                                </span>
                                <select name="EasyExplore" data-custom-setting>
                                    <option value="true" selected="@(world.Settings.EasyExplore ? "selected" : null)">True</option>
                                    <option value="false" selected="@(!world.Settings.EasyExplore ? "selected" : null)">False</option>
                                </select>
                            </label>

                            <div class="settings-grid">
                                <label>
                                    <span class="field-label">
                                        Enemy health
                                        <button class="help-button" type="button" aria-label="Enemy health help" data-tooltip="Enemy health multiplier. Default 1.0. Range 0.2 to 5.0.">?</button>
                                    </span>
                                    <input type="number" name="MobHealthMultiplier" min="0.2" max="5" step="0.01" value="@Model.FormatNumber(world.Settings.MobHealthMultiplier)" data-custom-setting />
                                </label>
                                <label>
                                    <span class="field-label">
                                        Enemy damage
                                        <button class="help-button" type="button" aria-label="Enemy damage help" data-tooltip="Enemy damage multiplier. Default 1.0. Range 0.2 to 5.0.">?</button>
                                    </span>
                                    <input type="number" name="MobDamageMultiplier" min="0.2" max="5" step="0.01" value="@Model.FormatNumber(world.Settings.MobDamageMultiplier)" data-custom-setting />
                                </label>
                                <label>
                                    <span class="field-label">
                                        Enemy ship health
                                        <button class="help-button" type="button" aria-label="Enemy ship health help" data-tooltip="Enemy ship health multiplier. Default 1.0. Range 0.4 to 5.0.">?</button>
                                    </span>
                                    <input type="number" name="ShipsHealthMultiplier" min="0.4" max="5" step="0.01" value="@Model.FormatNumber(world.Settings.ShipsHealthMultiplier)" data-custom-setting />
                                </label>
                                <label>
                                    <span class="field-label">
                                        Enemy ship damage
                                        <button class="help-button" type="button" aria-label="Enemy ship damage help" data-tooltip="Enemy ship damage multiplier. Default 1.0. Range 0.2 to 2.5.">?</button>
                                    </span>
                                    <input type="number" name="ShipsDamageMultiplier" min="0.2" max="2.5" step="0.01" value="@Model.FormatNumber(world.Settings.ShipsDamageMultiplier)" data-custom-setting />
                                </label>
                                <label>
                                    <span class="field-label">
                                        Boarding difficulty
                                        <button class="help-button" type="button" aria-label="Boarding difficulty help" data-tooltip="How many enemy sailors must be defeated to win a boarding action. Default 1.0. Range 0.2 to 5.0.">?</button>
                                    </span>
                                    <input type="number" name="BoardingDifficultyMultiplier" min="0.2" max="5" step="0.01" value="@Model.FormatNumber(world.Settings.BoardingDifficultyMultiplier)" data-custom-setting />
                                </label>
                                <label>
                                    <span class="field-label">
                                        Co-op enemy scaling
                                        <button class="help-button" type="button" aria-label="Co-op enemy scaling help" data-tooltip="Adjusts enemy health and posture loss based on player count. Default 1.0. Range 0.0 to 2.0.">?</button>
                                    </span>
                                    <input type="number" name="CoopStatsCorrectionModifier" min="0" max="2" step="0.01" value="@Model.FormatNumber(world.Settings.CoopStatsCorrectionModifier)" data-custom-setting />
                                </label>
                                <label>
                                    <span class="field-label">
                                        Co-op ship scaling
                                        <button class="help-button" type="button" aria-label="Co-op ship scaling help" data-tooltip="Adjusts enemy ship health based on player count. Default 0.0. Range 0.0 to 2.0.">?</button>
                                    </span>
                                    <input type="number" name="CoopShipStatsCorrectionModifier" min="0" max="2" step="0.01" value="@Model.FormatNumber(world.Settings.CoopShipStatsCorrectionModifier)" data-custom-setting />
                                </label>
                                <label>
                                    <span>Combat difficulty</span>
                                    <select name="CombatDifficulty" data-custom-setting>
                                        <option value="Easy" selected="@(world.Settings.CombatDifficulty.Equals("Easy", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Easy</option>
                                        <option value="Normal" selected="@(world.Settings.CombatDifficulty.Equals("Normal", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Normal</option>
                                        <option value="Hard" selected="@(world.Settings.CombatDifficulty.Equals("Hard", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Hard</option>
                                    </select>
                                </label>
                            </div>

                            <button class="button secondary" type="submit">Save World Settings</button>
                        </form>
                    </details>
                </article>
            }
        </div>
    }
    else
    {
        <div class="empty">No worlds were found. Check the configured Windrose server path.</div>
    }
</section>
