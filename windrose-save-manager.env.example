# Optional environment overrides for Windrose Save Manager.
# Install as: /etc/default/windrose-save-manager

# Where the Windrose container persists server files.
Windrose__ServerRoot=/opt/windrose/server-files

# Where docker compose should be executed.
Windrose__ComposeDirectory=/opt/windrose

# Full path to the Windrose docker-compose.yml file.
Windrose__ComposeFile=/opt/windrose/docker-compose.yml

# Docker Compose service name for the Windrose server.
Windrose__ServiceName=windrose

# Where timestamped backups are written.
Windrose__BackupsRoot=/opt/windrose/world-backups

# Where optional local world display labels are stored.
Windrose__LabelsPath=/opt/windrose/world-labels.json

# Docker executable name or full path.
Windrose__DockerCommand=docker

# Set false if you want the app to edit files without stopping/starting Docker.
Windrose__ManageContainer=true

# Bind address/port for the web UI.
ASPNETCORE_URLS=http://0.0.0.0:5085
